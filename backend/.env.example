# API Security
API_KEY=change_this_to_a_random_secret_key

# Google Gemini (free tier)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Database (PostgreSQL)
DATABASE_URL=postgresql://fundmanager:password@localhost:5432/fundmanager

# Redis
REDIS_URL=redis://localhost:6379/0

# Settings
SCREENER_TOP_N=30
POLL_INTERVAL_MINUTES=240
MAX_POSITIONS=10
DEBUG=false
